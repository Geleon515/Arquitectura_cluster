<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="arqui.grupo5.vendiasender.controller.SenderController"
            prefWidth="720" prefHeight="580">

    <!-- Cabecera -->
    <top>
        <VBox style="-fx-background-color: #1a237e; -fx-padding: 14 16 14 16;">
            <Label text="VendiaSender — LogiMarket Peru S.A."
                   style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
            <Label text="Sincronizacion de ventas al servidor central"
                   style="-fx-text-fill: #90caf9; -fx-font-size: 12;"/>
        </VBox>
    </top>

    <!-- Contenido principal -->
    <center>
        <VBox spacing="10" style="-fx-padding: 12;">

            <!-- Seccion: Archivo -->
            <TitledPane text="Archivo de ventas" collapsible="false" maxHeight="-Infinity">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                    <TextField fx:id="txtRutaDat"
                               promptText="Ruta de ventas.dat (ej: C:\datos\ventas.dat)"
                               HBox.hgrow="ALWAYS"/>
                    <Button text="Examinar..." onAction="#onBrowse"/>
                    <Button text="Cargar" onAction="#onCargar"
                            style="-fx-font-weight: bold;"/>
                </HBox>
            </TitledPane>

            <!-- Seccion: Carpeta compartida -->
            <TitledPane text="Carpeta compartida (destino)" collapsible="false" maxHeight="-Infinity">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                    <TextField fx:id="txtCarpetaDatos"
                               promptText="Ruta de carpeta DATOS (ej: C:\Users\USER\Desktop\DATOS)"
                               HBox.hgrow="ALWAYS"/>
                    <Button text="Examinar carpeta..." onAction="#onBrowseCarpeta"/>
                </HBox>
            </TitledPane>

            <!-- Tabla de pendientes -->
            <VBox spacing="4" VBox.vgrow="ALWAYS">
                <Label text="Ventas pendientes de envio:"
                       style="-fx-font-weight: bold;"/>
                <TableView fx:id="tablaPendientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID Venta"    prefWidth="195"/>
                        <TableColumn fx:id="colVendedor" text="Vendedor"    prefWidth="140"/>
                        <TableColumn fx:id="colFecha"    text="Fecha"       prefWidth="150"/>
                        <TableColumn fx:id="colMonto"    text="Monto Total" prefWidth="120"/>
                    </columns>
                    <placeholder>
                        <Label text="No hay ventas pendientes o no se ha cargado el archivo"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <!-- Panel inferior: acciones + log -->
    <bottom>
        <VBox spacing="6"
              style="-fx-padding: 10; -fx-background-color: #fafafa; -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;">

            <HBox spacing="14" alignment="CENTER_LEFT">
                <Button fx:id="btnEnviar"
                        text="Enviar al Servidor"
                        onAction="#onEnviar"
                        disable="true"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 7 22; -fx-font-size: 13;"/>
                <Label fx:id="lblEstado"
                       text="Esperando..."
                       style="-fx-text-fill: #757575; -fx-font-style: italic;"/>
            </HBox>

            <Label text="Registro de actividad:" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="txtLog"
                      editable="false"
                      prefHeight="125"
                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11;"/>
        </VBox>
    </bottom>

</BorderPane>
